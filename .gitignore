# Lead Vaults Finance — .gitignore

# Database
data/
*.db
*.db.bak
*.db-journal
*.db-wal

# Backups
backups/
*.db.gz
*.db.gpg
*.tar.gz

# Logs
logs/
*.log
*.err

# Uploads (receipts)
uploads/*

# Python
__pycache__/
*.pyc
*.pyo
venv/
*.egg-info/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
.env.local
*.key

# WireGuard (machine-specific)
wireguard/
scripts/
*.plist
setup-wireguard.sh

# Temp
write_*
tmp/
temp/
